rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isMember(householdId) {
      return isAuthenticated() && 
        request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
    }

    function isValidHousehold(data) {
      return data.keys().hasAll(['name', 'ownerId', 'members']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.ownerId == request.auth.uid &&
             data.members is list && data.members.size() > 0 && data.members.size() < 10 &&
             request.auth.uid in data.members;
    }

    function isValidMeal(data) {
      return data.keys().hasAll(['date', 'type', 'name', 'updatedBy', 'updatedAt']) &&
             data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             data.type in ['lunch', 'dinner'] &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.updatedBy == request.auth.uid &&
             (!('recipeUrl' in data) || (data.recipeUrl is string && data.recipeUrl.size() < 1000));
    }

    // Households
    match /households/{householdId} {
      // Allow get for any authenticated user so they can see the household they are joining
      allow get: if isAuthenticated();
      // Only members can list households (though not used in this app)
      allow list: if isAuthenticated() && (request.auth.uid in resource.data.members);
      
      allow create: if isAuthenticated() && isValidHousehold(request.resource.data);
      
      // Allow update if:
      // 1. User is the owner (full update)
      // 2. User is a member (full update)
      // 3. User is joining (adding themselves to members)
      allow update: if isAuthenticated() && (
        (request.auth.uid in resource.data.members) || 
        (
          request.resource.data.members.hasAll(resource.data.members) &&
          request.resource.data.members.size() == resource.data.members.size() + 1 &&
          request.auth.uid in request.resource.data.members &&
          request.resource.data.name == resource.data.name &&
          request.resource.data.ownerId == resource.data.ownerId
        )
      );
      
      // Meals Subcollection
      match /meals/{mealId} {
        allow read: if isMember(householdId);
        allow create: if isMember(householdId) && isValidMeal(request.resource.data);
        allow update: if isMember(householdId) && isValidMeal(request.resource.data);
        allow delete: if isMember(householdId);
      }
    }
  }
}
